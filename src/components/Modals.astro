---
---
<!-- Profile Modals -->
<div class="fixed inset-0 z-50 bg-black/50 hidden items-center justify-center" id="modalAlex" data-modal>
    <div class="bg-bg-dark rounded-xl shadow-2xl max-w-lg w-full mx-4 max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between p-4 border-b border-white/10">
            <h5 class="font-bold text-lg" id="modalAlexLabel"><i class="bi bi-person-heart mr-2"></i>Álex's Profile</h5>
            <button type="button" class="text-white/50 hover:text-white text-2xl leading-none transition-colors" data-modal-close>&times;</button>
        </div>
        <div class="p-4">
            <div class="text-center mb-4">
                <img src="/images/poems/Me hablaste.png" alt="Álex's poem" class="max-h-[300px] rounded-lg shadow-lg inline-block">
            </div>
            <div class="flex items-center mb-3">
                <div class="bg-rhymance-dark text-white rounded-full flex items-center justify-center mr-3 w-[50px] h-[50px] shrink-0">
                    <i class="bi bi-person-fill text-2xl"></i>
                </div>
                <div>
                    <h4 class="mb-0 font-bold">Álex <span class="bg-gray-600 text-white text-xs px-2 py-1 rounded-full">23 years old</span></h4>
                    <small class="text-white/50">Madrid, Spain</small>
                </div>
            </div>
            <hr class="border-white/10 my-3">
            <div class="mb-3">
                <h6 class="font-bold">About me</h6>
                <p class="text-white/50">Night poet and lover of metaphors. I believe that words have the power to connect souls. Seeking someone who understands the language of the heart.</p>
            </div>
            <div class="mb-3">
                <h6 class="font-bold">Interests</h6>
                <span class="inline-block bg-white/10 text-white text-xs px-2 py-1 rounded-full mr-1 mb-1">Romantic poetry</span>
                <span class="inline-block bg-white/10 text-white text-xs px-2 py-1 rounded-full mr-1 mb-1">Literature</span>
                <span class="inline-block bg-white/10 text-white text-xs px-2 py-1 rounded-full mr-1 mb-1">Indie music</span>
                <span class="inline-block bg-white/10 text-white text-xs px-2 py-1 rounded-full mr-1 mb-1">Coffee</span>
            </div>
            <div class="mb-3">
                <h6 class="font-bold">Poetic Style</h6>
                <p class="text-white/50 mb-0">Free verse, with touches of surrealism and contemporary romanticism.</p>
            </div>
        </div>
        <div class="flex justify-end gap-2 p-4 border-t border-white/10">
            <button type="button" class="border border-gray-500 text-gray-400 px-4 py-2 rounded-lg hover:bg-gray-700 transition-colors modal-nope-btn" data-modal-close>Nope</button>
            <button type="button" class="bg-passion text-white px-4 py-2 rounded-lg hover:bg-passion-dark transition-colors modal-like-btn">Like</button>
        </div>
    </div>
</div>

<div class="fixed inset-0 z-50 bg-black/50 hidden items-center justify-center" id="modalLimary" data-modal>
    <div class="bg-bg-dark rounded-xl shadow-2xl max-w-lg w-full mx-4 max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between p-4 border-b border-white/10 bg-rhymance-dark text-white rounded-t-xl">
            <h5 class="font-bold text-lg" id="modalLimaryLabel"><i class="bi bi-person-heart mr-2"></i>Limary's Profile</h5>
            <button type="button" class="text-white/50 hover:text-white text-2xl leading-none transition-colors" data-modal-close>&times;</button>
        </div>
        <div class="p-4">
            <div class="text-center mb-4">
                <img src="/images/poems/No escribí.png" alt="Limary's poem" class="max-h-[300px] rounded-lg shadow-lg inline-block">
            </div>
            <div class="flex items-center mb-3">
                <div class="bg-rhymance-dark text-white rounded-full flex items-center justify-center mr-3 w-[50px] h-[50px] shrink-0">
                    <i class="bi bi-person-fill text-2xl"></i>
                </div>
                <div>
                    <h4 class="mb-0 font-bold">Limary <span class="bg-gray-600 text-white text-xs px-2 py-1 rounded-full">27 years old</span></h4>
                    <small class="text-white/50">Barcelona, Spain</small>
                </div>
            </div>
            <hr class="border-white/10 my-3">
            <div class="mb-3">
                <h6 class="font-bold">About me</h6>
                <p class="text-white/50">Writer of emotions and collector of sunsets. My verses are born from silence and seek to find an echo in another sensitive heart.</p>
            </div>
            <div class="mb-3">
                <h6 class="font-bold">Interests</h6>
                <span class="inline-block bg-white/10 text-white text-xs px-2 py-1 rounded-full mr-1 mb-1">Contemporary poetry</span>
                <span class="inline-block bg-white/10 text-white text-xs px-2 py-1 rounded-full mr-1 mb-1">Art</span>
                <span class="inline-block bg-white/10 text-white text-xs px-2 py-1 rounded-full mr-1 mb-1">Nature</span>
                <span class="inline-block bg-white/10 text-white text-xs px-2 py-1 rounded-full mr-1 mb-1">Photography</span>
            </div>
            <div class="mb-3">
                <h6 class="font-bold">Poetic Style</h6>
                <p class="text-white/50 mb-0">Micropoetry and haikus, with influences from Latin American poets.</p>
            </div>
        </div>
        <div class="flex justify-end gap-2 p-4 border-t border-white/10">
            <button type="button" class="border border-gray-500 text-gray-400 px-4 py-2 rounded-lg hover:bg-gray-700 transition-colors modal-nope-btn" data-modal-close>Nope</button>
            <button type="button" class="bg-passion text-white px-4 py-2 rounded-lg hover:bg-passion-dark transition-colors modal-like-btn">Like</button>
        </div>
    </div>
</div>
