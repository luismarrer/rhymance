---
---
<!-- Profile Modals -->
<div class="modal fade" id="modalAlex" tabindex="-1" aria-labelledby="modalAlexLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalAlexLabel"><i class="bi bi-person-heart me-2"></i>Álex's Profile</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="text-center mb-4">
                    <img src="/images/poems/Me hablaste.png" alt="Álex's poem" class="img-fluid rounded shadow" style="max-height: 300px;">
                </div>
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-rhymancedark text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                        <i class="bi bi-person-fill fs-3"></i>
                    </div>
                    <div>
                        <h4 class="mb-0">Álex <span class="badge bg-secondary">23 years old</span></h4>
                        <small class="text-light">Madrid, Spain</small>
                    </div>
                </div>
                <hr>
                <div class="mb-3">
                    <h6 class="fw-bold">About me</h6>
                    <p class="text-light">Night poet and lover of metaphors. I believe that words have the power to connect souls. Seeking someone who understands the language of the heart.</p>
                </div>
                <div class="mb-3">
                    <h6 class="fw-bold">Interests</h6>
                    <span class="badge bg-light text-dark me-1">Romantic poetry</span>
                    <span class="badge bg-light text-dark me-1">Literature</span>
                    <span class="badge bg-light text-dark me-1">Indie music</span>
                    <span class="badge bg-light text-dark me-1">Coffee</span>
                </div>
                <div class="mb-3">
                    <h6 class="fw-bold">Poetic Style</h6>
                    <p class="text-light mb-0">Free verse, with touches of surrealism and contemporary romanticism.</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Nope</button>
                <button type="button" class="btn btn-danger">Like</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalLimary" tabindex="-1" aria-labelledby="modalLimaryLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-rhymancedark text-white">
                <h5 class="modal-title" id="modalLimaryLabel"><i class="bi bi-person-heart me-2"></i>Limary's Profile</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="text-center mb-4">
                    <img src="/images/poems/No escribí.png" alt="Limary's poem" class="img-fluid rounded shadow" style="max-height: 300px;">
                </div>
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-rhymancedark text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                        <i class="bi bi-person-fill fs-3"></i>
                    </div>
                    <div>
                        <h4 class="mb-0">Limary <span class="badge bg-secondary">27 years old</span></h4>
                        <small class="text-light">Barcelona, Spain</small>
                    </div>
                </div>
                <hr>
                <div class="mb-3">
                    <h6 class="fw-bold">About me</h6>
                    <p class="text-light">Writer of emotions and collector of sunsets. My verses are born from silence and seek to find an echo in another sensitive heart.</p>
                </div>
                <div class="mb-3">
                    <h6 class="fw-bold">Interests</h6>
                    <span class="badge bg-light text-dark me-1">Contemporary poetry</span>
                    <span class="badge bg-light text-dark me-1">Art</span>
                    <span class="badge bg-light text-dark me-1">Nature</span>
                    <span class="badge bg-light text-dark me-1">Photography</span>
                </div>
                <div class="mb-3">
                    <h6 class="fw-bold">Poetic Style</h6>
                    <p class="text-light mb-0">Micropoetry and haikus, with influences from Latin American poets.</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Nope</button>
                <button type="button" class="btn btn-danger">Like</button>
            </div>
        </div>
    </div>
</div>
