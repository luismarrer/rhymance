---
<footer class="bg-gray-900 text-white pt-20 pb-3">
    <div class="max-w-7xl mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
            <!-- Column 1: Logo and description -->
            <div>
                <div class="flex items-center mb-3">
                    <img src="/images/logo.png" alt="Rhymance logo" width="50" class="mr-2">
                    <h5 class="mb-0 font-bold">Rhymance</h5>
                </div>
                <p class="text-white/50 text-sm">Connecting souls through poetry. Find your perfect literary match.</p>
                <p class="text-white/50 text-sm mb-0">Made with ❤️ by Luis Marrero</p>
            </div>

            <!-- Column 2: Contact -->
            <div>
                <h6 class="font-bold mb-3">Contact</h6>
                <ul class="list-none p-0 text-white/50 text-sm">
                    <li class="mb-2">
                        <i class="bi bi-geo-alt-fill mr-2"></i>
                        <a href="https://www.google.com/maps/place/San+Juan,+Puerto+Rico/@18.4041765,-66.0604089,12z/data=!3m1!4b1!4m6!3m5!1s0x8c03686fe268196f:0xad6b7f0f5c935adc!8m2!3d18.4153108!4d-66.0593509!16zL20vMGZ3NHY?entry=ttu&g_ep=EgoyMDI1MTIwOS4wIKXMDSoKLDEwMDc5MjA3M0gBUAM%3D" target="_blank" rel="noopener noreferrer" class="text-white/50 no-underline hover:text-white transition-colors">San Juan, Puerto Rico</a>
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-envelope-fill mr-2"></i>
                        <a href="mailto:luismarrer.dev@gmail.com" class="text-white/50 no-underline hover:text-white transition-colors">luismarrer.dev@gmail.com</a>
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-telephone-fill mr-2"></i>
                        <a href="tel:+17874870310" class="text-white/50 no-underline hover:text-white transition-colors">+1 (787) 487-0310</a>
                    </li>
                </ul>
            </div>

            <!-- Column 3: Quick Links -->
            <div>
                <h6 class="font-bold mb-3">Quick Links</h6>
                <ul class="list-none p-0 text-white/50 text-sm mb-3">
                    <li class="mb-2"><a href="#home" class="text-white/50 no-underline hover:text-white transition-colors">Home</a></li>
                    <li class="mb-2"><a href="#app" class="text-white/50 no-underline hover:text-white transition-colors">App</a></li>
                    <li class="mb-2"><a href="#features" class="text-white/50 no-underline hover:text-white transition-colors">Features</a></li>
                    <li class="mb-2"><a href="/contact" class="text-white/50 no-underline hover:text-white transition-colors">Contact</a></li>
                    <li class="mb-2"><a href="https://luismarrer.github.io/en/" target="_blank" rel="noopener noreferrer" class="text-white/50 no-underline hover:text-white transition-colors">Portfolio</a></li>
                </ul>
            </div>

            <!-- Column 4: Social Media -->
            <div>
                <h6 class="font-bold mb-3">Follow Us</h6>
                <div class="flex gap-3">
                    <a href="https://www.linkedin.com/in/luismarrer/" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-white transition-colors hover:-translate-y-1 transform" aria-label="LinkedIn">
                        <i class="bi bi-linkedin text-2xl"></i>
                    </a>
                    <a href="https://x.com/luismarrer_dev" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-white transition-colors hover:-translate-y-1 transform" aria-label="Twitter/X">
                        <i class="bi bi-twitter-x text-2xl"></i>
                    </a>
                    <a href="https://github.com/luismarrer" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-white transition-colors hover:-translate-y-1 transform" aria-label="GitHub">
                        <i class="bi bi-github text-2xl"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Copyright -->
        <hr class="border-gray-600 my-4">
        <div class="flex flex-col md:flex-row justify-between">
            <div class="text-center md:text-left">
                <p class="text-white/50 text-sm mb-0">&copy; 2025 Rhymance. All rights reserved.</p>
            </div>

            <div class="text-center md:text-right">
                <a href="/privacy" class="text-white/50 no-underline text-sm mr-3 hover:text-white transition-colors">Privacy Policy</a>
                <a href="/terms" class="text-white/50 no-underline text-sm hover:text-white transition-colors">Terms and Conditions</a>
                <a href="/cookies" class="text-white/50 no-underline text-sm ml-3 hover:text-white transition-colors">Cookie Policy</a>
            </div>
        </div>
    </div>
</footer>
