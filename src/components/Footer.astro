            </div>

            <div class="col-md-6 text-center text-md-end">
                <a href="/privacy" class="text-white-50 text-decoration-none small me-3">Privacy Policy</a>
                <a href="/terms" class="text-white-50 text-decoration-none small">Terms and Conditions</a>
                <a href="/cookies" class="text-white-50 text-decoration-none small ms-3">Cookie Policy</a>
