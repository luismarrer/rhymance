<footer class="bg-dark text-white pt-5 pb-3">
    <div class="container">
        <div class="row g-4">
            <!-- Column 1: Logo and description -->
            <div class="col-md-3">
                <div class="d-flex align-items-center mb-3">
                    <img src="/images/logo.png" alt="Rhymance logo" width="50" class="me-2">
                    <h5 class="mb-0 fw-bold">Rhymance</h5>
                </div>
                <p class="text-white-50 small">Connecting souls through poetry. Find your perfect literary match.</p>
                <p class="text-white-50 small mb-0">Made with ❤️ by Luis Marrero</p>
            </div>

            <!-- Column 2: Contact -->
            <div class="col-md-3">
                <h6 class="fw-bold mb-3">Contact</h6>
                <ul class="list-unstyled text-white-50 small">
                    <li class="mb-2">
                        <i class="bi bi-geo-alt-fill me-2"></i>
                        <a href="https://www.google.com/maps/place/San+Juan,+Puerto+Rico/@18.4041765,-66.0604089,12z/data=!3m1!4b1!4m6!3m5!1s0x8c03686fe268196f:0xad6b7f0f5c935adc!8m2!3d18.4153108!4d-66.0593509!16zL20vMGZ3NHY?entry=ttu&g_ep=EgoyMDI1MTIwOS4wIKXMDSoKLDEwMDc5MjA3M0gBUAM%3D" target="_blank" rel="noopener noreferrer" class="text-white-50 text-decoration-none">San Juan, Puerto Rico</a>
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-envelope-fill me-2"></i>
                        <a href="mailto:luismarrer.dev@gmail.com" class="text-white-50 text-decoration-none">luismarrer.dev@gmail.com</a>
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-telephone-fill me-2"></i>
                        <a href="tel:+17874870310" class="text-white-50 text-decoration-none">+1 (787) 487-0310</a>
                    </li>
                </ul>
            </div>

            <!-- Column 3: Quick Links -->
            <div class="col-md-3">
                <h6 class="fw-bold mb-3">Quick Links</h6>
                <ul class="list-unstyled text-white-50 small mb-3">
                    <li class="mb-2"><a href="#home" class="text-white-50 text-decoration-none">Home</a></li>
                    <li class="mb-2"><a href="#app" class="text-white-50 text-decoration-none">App</a></li>
                    <li class="mb-2"><a href="#features" class="text-white-50 text-decoration-none">Features</a></li>
                    <li class="mb-2"><a href="/contact" class="text-white-50 text-decoration-none">Contact</a></li>
                    <li class="mb-2"><a href="https://luismarrer.github.io/en/" target="_blank" rel="noopener noreferrer" class="text-white-50 text-decoration-none">Portfolio</a></li>
                </ul>
            </div>

            <!-- Column 4: Social Media -->
            <div class="col-md-3">
                <h6 class="fw-bold mb-3">Follow Us</h6>
                <div class="d-flex gap-3">
                    <a href="https://www.linkedin.com/in/luismarrer/" target="_blank" rel="noopener noreferrer" class="text-white-50" aria-label="LinkedIn">
                        <i class="bi bi-linkedin fs-4"></i>
                    </a>
                    <a href="https://x.com/luismarrer_dev" target="_blank" rel="noopener noreferrer" class="text-white-50" aria-label="Twitter/X">
                        <i class="bi bi-twitter-x fs-4"></i>
                    </a>
                    <a href="https://github.com/luismarrer" target="_blank" rel="noopener noreferrer" class="text-white-50" aria-label="GitHub">
