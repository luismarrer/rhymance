---
---
<div class="carousel-container" id="home">
    <div id="carouselExampleApp" class="carousel slide carousel-modern">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#carouselExampleApp" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#carouselExampleApp" data-bs-slide-to="1" aria-label="Slide 2"></button>
        </div>
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="/images/pexels-photo-1591447.jpeg" class="d-block w-100" alt="">
                <div class="carousel-caption d-none d-md-block ">
                    <h5>Find love through poetry</h5>
                    <p>Connect with like-minded souls by swiping verses, not photos. Rhymance revolutionizes online dating.</p>
                </div>
            </div>
            <div class="carousel-item">
                <img src="/images/carrousel.png" class="d-block w-100" alt="">
                <div class="carousel-caption d-none d-md-block">
                    <h5>Swipe verses, find love</h5>
                    <p>Every poem is a window to the soul. Discover deeper connections that go beyond appearances.</p>
                </div>
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleApp" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleApp" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>
</div>
