---
---
<div class="carousel-container" id="home">
    <div id="carouselExampleApp" class="carousel-modern relative" data-carousel>
        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-10">
            <button type="button" data-carousel-indicator="0" class="w-3 h-3 rounded-full bg-white/50 transition-colors carousel-indicator active" aria-label="Slide 1"></button>
            <button type="button" data-carousel-indicator="1" class="w-3 h-3 rounded-full bg-white/50 transition-colors carousel-indicator" aria-label="Slide 2"></button>
        </div>
        <div class="carousel-inner relative w-full h-full overflow-hidden rounded-3xl">
            <div class="carousel-slide absolute inset-0 transition-opacity duration-500 opacity-100 z-10" data-carousel-slide="0">
                <img src="/images/pexels-photo-1591447.jpeg" class="block w-full h-full object-cover rounded-3xl" alt="">
                <div class="carousel-caption absolute bottom-0 left-0 right-0 p-8 text-white text-center hidden md:block">
                    <h5>Find love through poetry</h5>
                    <p>Connect with like-minded souls by swiping verses, not photos. Rhymance revolutionizes online dating.</p>
                </div>
            </div>
            <div class="carousel-slide absolute inset-0 transition-opacity duration-500 opacity-0 z-0" data-carousel-slide="1">
                <img src="/images/carrousel.png" class="block w-full h-full object-cover rounded-3xl" alt="">
                <div class="carousel-caption absolute bottom-0 left-0 right-0 p-8 text-white text-center hidden md:block">
                    <h5>Swipe verses, find love</h5>
                    <p>Every poem is a window to the soul. Discover deeper connections that go beyond appearances.</p>
                </div>
            </div>
        </div>
        <button class="absolute left-4 top-1/2 -translate-y-1/2 z-20 w-10 h-10 flex items-center justify-center rounded-full bg-black/30 text-white hover:bg-black/50 transition-colors" type="button" data-carousel-prev>
            <span class="text-2xl" aria-hidden="true">&#8249;</span>
            <span class="sr-only">Previous</span>
        </button>
        <button class="absolute right-4 top-1/2 -translate-y-1/2 z-20 w-10 h-10 flex items-center justify-center rounded-full bg-black/30 text-white hover:bg-black/50 transition-colors" type="button" data-carousel-next>
            <span class="text-2xl" aria-hidden="true">&#8250;</span>
            <span class="sr-only">Next</span>
        </button>
    </div>
</div>
