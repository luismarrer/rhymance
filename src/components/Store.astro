---
---
<section id="store" class="py-20 bg-gray-900 text-white">
    <div class="max-w-7xl mx-auto px-4">
        <div class="text-center mb-12">
            <h2 class="text-4xl font-bold mb-4">Start your poetic journey today!</h2>
            <p class="text-xl text-white/50 mb-4">Download Rhymance and discover a world where words unite hearts.</p>
        </div>

        <div class="flex justify-center">
            <div class="w-full lg:w-2/3">
                <div class="flex flex-col divide-y divide-white/10 rounded-xl overflow-hidden border border-white/10">
                    <!-- App Store -->
                    <a href="https://www.apple.com/app-store/" class="store-item block p-4 no-underline text-white hover:bg-white/[0.15] transition-colors">
                        <div class="flex items-center">
                            <div class="mr-4">
                                <i class="bi bi-apple text-4xl"></i>
                            </div>
                            <div class="flex-1">
                                <div class="flex justify-between items-start mb-1">
                                    <h5 class="mb-0 font-bold text-white">App Store</h5>
                                    <span class="bg-green-500 text-white text-xs px-3 py-1 rounded-full">
                                        <i class="bi bi-download mr-1"></i>
                                        2.5M+
                                    </span>
                                </div>
                                <p class="mb-1 text-white/50">
                                    <i class="bi bi-geo-alt-fill mr-1"></i>
                                    United States, Cupertino
                                </p>
                                <p class="mb-0 text-sm text-white/50">Available for iOS 18.0 or higher | Contact: support@apple.com</p>
                            </div>
                            <div>
                                <i class="bi bi-chevron-right text-white/50"></i>
                            </div>
                        </div>
                    </a>

                    <!-- Play Store -->
                    <a href="https://play.google.com/store/apps" class="store-item block p-4 no-underline text-white hover:bg-white/[0.15] transition-colors">
                        <div class="flex items-center">
                            <div class="mr-4">
                                <i class="bi bi-google-play text-4xl"></i>
                            </div>
                            <div class="flex-1">
                                <div class="flex justify-between items-start mb-1">
                                    <h5 class="mb-0 font-bold text-white">Google Play Store</h5>
                                    <span class="bg-green-500 text-white text-xs px-3 py-1 rounded-full">
                                        <i class="bi bi-download mr-1"></i>
                                        5M+
                                    </span>
                                </div>
                                <p class="mb-1 text-white/50">
                                    <i class="bi bi-geo-alt-fill mr-1"></i>
                                    United States, Mountain View
                                </p>
                                <p class="mb-0 text-sm text-white/50">Available for Android 16.0 or higher | Contact: play-support@google.com</p>
                            </div>
                            <div>
                                <i class="bi bi-chevron-right text-white/50"></i>
                            </div>
                        </div>
                    </a>

                    <!-- Web Version -->
                    <a href="https://luismarrer.github.io/en/" class="store-item block p-4 no-underline text-white hover:bg-white/[0.15] transition-colors">
                        <div class="flex items-center">
                            <div class="mr-4">
                                <i class="bi bi-globe2 text-4xl"></i>
                            </div>
                            <div class="flex-1">
                                <div class="flex justify-between items-start mb-1">
                                    <h5 class="mb-0 font-bold text-white">Available on Web</h5>
                                    <span class="bg-green-500 text-white text-xs px-3 py-1 rounded-full">
                                        <i class="bi bi-globe2 mr-1"></i>
                                        850K+
                                    </span>
                                </div>
                                <p class="mb-1 text-white/50">
                                    <i class="bi bi-geo-alt-fill mr-1"></i>
                                    Puerto Rico, San Juan
                                </p>
                                <p class="mb-0 text-sm text-white/50">Access from any browser | Contact: luismarrer.dev@gmail.com</p>
                            </div>
                            <div>
                                <i class="bi bi-chevron-right text-white/50"></i>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
