---
---
<section id="store" class="py-5 bg-dark text-white">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold mb-4">Start your poetic journey today!</h2>
            <p class="lead text-white-50 mb-4">Download Rhymance and discover a world where words unite hearts.</p>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="list-group">
                    <!-- App Store -->
                    <a href="https://www.apple.com/app-store/" class="list-group-item list-group-item-action p-4">
                        <div class="d-flex align-items-center">
                            <div class="me-4">
                                <i class="bi bi-apple fs-1"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <h5 class="mb-0 fw-bold text-white">App Store</h5>
                                    <span class="badge bg-success rounded-pill">
                                        <i class="bi bi-download me-1"></i>
                                        2.5M+
                                    </span>
                                </div>
                                <p class="mb-1 text-white-50">
                                    <i class="bi bi-geo-alt-fill me-1"></i>
                                    United States, Cupertino
                                </p>
                                <p class="mb-0 small text-white-50">Available for iOS 18.0 or higher | Contact: support@apple.com</p>
                            </div>
                            <div>
                                <i class="bi bi-chevron-right text-white-50"></i>
                            </div>
                        </div>
                    </a>

                    <!-- Play Store -->
                    <a href="https://play.google.com/store/apps" class="list-group-item list-group-item-action p-4">
                        <div class="d-flex align-items-center">
                            <div class="me-4">
                                <i class="bi bi-google-play fs-1"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <h5 class="mb-0 fw-bold text-white">Google Play Store</h5>
                                    <span class="badge bg-success rounded-pill">
                                        <i class="bi bi-download me-1"></i>
                                        5M+
                                    </span>
                                </div>
                                <p class="mb-1 text-white-50">
                                    <i class="bi bi-geo-alt-fill me-1"></i>
                                    United States, Mountain View
                                </p>
                                <p class="mb-0 small text-white-50">Available for Android 16.0 or higher | Contact: play-support@google.com</p>
                            </div>
                            <div>
                                <i class="bi bi-chevron-right text-white-50"></i>
                            </div>
                        </div>
                    </a>

                    <!-- Web Version -->
                    <a href="https://luismarrer.github.io/en/" class="list-group-item list-group-item-action p-4">
                        <div class="d-flex align-items-center">
                            <div class="me-4">
                                <i class="bi bi-globe2 fs-1"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <h5 class="mb-0 fw-bold text-white">Available on Web</h5>
                                    <span class="badge bg-success rounded-pill">
                                        <i class="bi bi-globe2 me-1"></i>
                                        850K+
                                    </span>
                                </div>
                                <p class="mb-1 text-white-50">
                                    <i class="bi bi-geo-alt-fill me-1"></i>
                                    Puerto Rico, San Juan
                                </p>
                                <p class="mb-0 small text-white-50">Access from any browser | Contact: luismarrer.dev@gmail.com</p>
                            </div>
                            <div>
                                <i class="bi bi-chevron-right text-white-50"></i>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
