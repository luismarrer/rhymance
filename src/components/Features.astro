---
---
<section id="features" class="py-20">
    <div class="max-w-7xl mx-auto px-4">
        <div class="flex justify-center">
            <div class="w-full lg:w-5/6">
                <div class="text-center mb-12">
                    <h2 class="text-5xl font-bold">Main Features</h2>
                    <p class="text-xl text-white/60">Everything you need to find love through poetry</p>
                </div>
                
                <div class="rounded-xl shadow-2xl overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead class="bg-rhymance-dark text-white">
                                <tr>
                                    <th class="py-3 ps-4 font-semibold"><i class="bi bi-gear-fill mr-2"></i>Feature</th>
                                    <th class="py-3 font-semibold"><i class="bi bi-info-circle-fill mr-2"></i>Description</th>
                                    <th class="py-3 text-center font-semibold"><i class="bi bi-star-fill mr-2"></i>Type</th>
                                    <th class="py-3 text-center pr-4 font-semibold"><i class="bi bi-check-circle-fill mr-2"></i>Status</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-white/10">
                                <tr class="hover:bg-white/5 transition-colors">
                                    <td class="py-4 ps-4">
                                        <strong><i class="bi bi-heart-fill text-passion mr-2"></i>Affinity Match</strong>
                                    </td>
                                    <td class="py-4">Algorithm that connects based on poetic tastes</td>
                                    <td class="py-4 text-center">
                                        <span class="bg-rhymance-dark text-white text-xs px-3 py-1 rounded-full">Premium</span>
                                    </td>
                                    <td class="py-4 text-center pr-4">
                                        <i class="bi bi-check-circle-fill text-green-500"></i> Active
                                    </td>
                                </tr>
                                <tr class="hover:bg-white/5 transition-colors">
                                    <td class="py-4 ps-4">
                                        <strong><i class="bi bi-person-circle text-cyan-400 mr-2"></i>Poetic Profiles</strong>
                                    </td>
                                    <td class="py-4">Create a unique profile that reflects your poetic soul</td>
                                    <td class="py-4 text-center">
                                        <span class="bg-green-500 text-white text-xs px-3 py-1 rounded-full">Included</span>
                                    </td>
                                    <td class="py-4 text-center pr-4">
                                        <i class="bi bi-check-circle-fill text-green-500"></i> Active
                                    </td>
                                </tr>
                                <tr class="hover:bg-white/5 transition-colors">
                                    <td class="py-4 ps-4">
                                        <strong><i class="bi bi-chat-dots-fill text-blue-500 mr-2"></i>Integrated Chat</strong>
                                    </td>
                                    <td class="py-4">Conversations started with inspiring verses</td>
                                    <td class="py-4 text-center">
                                        <span class="bg-green-500 text-white text-xs px-3 py-1 rounded-full">Included</span>
                                    </td>
                                    <td class="py-4 text-center pr-4">
                                        <i class="bi bi-check-circle-fill text-green-500"></i> Active
                                    </td>
                                </tr>
                                <tr class="hover:bg-white/5 transition-colors">
                                    <td class="py-4 ps-4">
                                        <strong><i class="bi bi-pen-fill text-amber-400 mr-2"></i>Create Poems</strong>
                                    </td>
                                    <td class="py-4">Tools to write and share your own verses</td>
                                    <td class="py-4 text-center">
                                        <span class="bg-green-500 text-white text-xs px-3 py-1 rounded-full">Included</span>
                                    </td>
                                    <td class="py-4 text-center pr-4">
                                        <i class="bi bi-check-circle-fill text-green-500"></i> Active
                                    </td>
                                </tr>
                                <tr class="hover:bg-white/5 transition-colors">
                                    <td class="py-4 ps-4">
                                        <strong><i class="bi bi-globe-americas text-green-500 mr-2"></i>Global Community</strong>
                                    </td>
                                    <td class="py-4">Connect with poets and romantics worldwide</td>
                                    <td class="py-4 text-center">
                                        <span class="bg-green-500 text-white text-xs px-3 py-1 rounded-full">Included</span>
                                    </td>
                                    <td class="py-4 text-center pr-4">
                                        <i class="bi bi-check-circle-fill text-green-500"></i> Active
                                    </td>
                                </tr>
                                <tr class="hover:bg-white/5 transition-colors">
                                    <td class="py-4 ps-4">
                                        <strong><i class="bi bi-shield-check text-rhymance-dark mr-2"></i>Profile Verification</strong>
                                    </td>
                                    <td class="py-4">Verification system for greater security</td>
                                    <td class="py-4 text-center">
                                        <span class="bg-rhymance-dark text-white text-xs px-3 py-1 rounded-full">Premium</span>
                                    </td>
                                    <td class="py-4 text-center pr-4">
                                        <i class="bi bi-hourglass-split text-amber-400"></i> Beta
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
