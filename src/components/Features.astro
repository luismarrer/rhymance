<section id="features" class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="text-center mb-5">
                    <h2 class="display-4 fw-bold">Main Features</h2>
                    <p class="lead text-body-color">Everything you need to find love through poetry</p>
                </div>
                
                <div class="card shadow-lg border-0">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 table-striped">
                                <thead class="bg-rhymancedark text-white">
                                    <tr>
                                        <th scope="col" class="py-3 ps-4 text-body"><i class="bi bi-gear-fill me-2"></i>Feature</th>
                                        <th scope="col" class="py-3 text-body"><i class="bi bi-info-circle-fill me-2"></i>Description</th>
                                        <th scope="col" class="py-3 text-center text-body"><i class="bi bi-star-fill me-2"></i>Type</th>
                                        <th scope="col" class="py-3 text-center pe-4 text-body"><i class="bi bi-check-circle-fill me-2"></i>Status</th>
                                    </tr>
                                </thead>
                                <tbody class="table-group-divider">
                                    <tr>
                                        <td class="py-4 ps-4 text-body">
                                            <strong><i class="bi bi-heart-fill text-danger me-2"></i>Affinity Match</strong>
                                        </td>
                                        <td class="py-4 text-body">Algorithm that connects based on poetic tastes</td>
                                        <td class="py-4 text-center">
                                            <span class="badge bg-rhymancedark">Premium</span>
                                        </td>
                                        <td class="py-4 text-center pe-4 text-body">
                                            <i class="bi bi-check-circle-fill text-success"></i> Active
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="py-4 ps-4 text-body">
                                            <strong><i class="bi bi-person-circle text-info me-2"></i>Poetic Profiles</strong>
                                        </td>
                                        <td class="py-4 text-body">Create a unique profile that reflects your poetic soul</td>
                                        <td class="py-4 text-center">
                                            <span class="badge bg-success">Included</span>
                                        </td>
                                        <td class="py-4 text-center pe-4 text-body">
                                            <i class="bi bi-check-circle-fill text-success"></i> Active
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="py-4 ps-4 text-body">
                                            <strong><i class="bi bi-chat-dots-fill text-primary me-2"></i>Integrated Chat</strong>
                                        </td>
                                        <td class="py-4 text-body">Conversations started with inspiring verses</td>
                                        <td class="py-4 text-center">
                                            <span class="badge bg-success">Included</span>
                                        </td>
                                        <td class="py-4 text-center pe-4 text-body">
                                            <i class="bi bi-check-circle-fill text-success"></i> Active
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="py-4 ps-4 text-body">
                                            <strong><i class="bi bi-pen-fill text-warning me-2"></i>Create Poems</strong>
                                        </td>
                                        <td class="py-4 text-body">Tools to write and share your own verses</td>
                                        <td class="py-4 text-center">
                                            <span class="badge bg-success">Included</span>
                                        </td>
                                        <td class="py-4 text-center pe-4 text-body">
                                            <i class="bi bi-check-circle-fill text-success"></i> Active
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="py-4 ps-4 text-body">
                                            <strong><i class="bi bi-globe-americas text-success me-2"></i>Global Community</strong>
                                        </td>
                                        <td class="py-4 text-body">Connect with poets and romantics worldwide</td>
                                        <td class="py-4 text-center">
                                            <span class="badge bg-success">Included</span>
                                        </td>
                                        <td class="py-4 text-center pe-4 text-body">
                                            <i class="bi bi-check-circle-fill text-success"></i> Active
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="py-4 ps-4 text-body">
                                            <strong><i class="bi bi-shield-check text-rhymancedark me-2"></i>Profile Verification</strong>
                                        </td>
                                        <td class="py-4 text-body">Verification system for greater security</td>
                                        <td class="py-4 text-center">
                                            <span class="badge bg-rhymancedark">Premium</span>
                                        </td>
                                        <td class="py-4 text-center pe-4 text-body">
                                            <i class="bi bi-hourglass-split text-warning"></i> Beta
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
