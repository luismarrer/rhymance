---
---
<section id="app" class="py-5">
    <div class="row flex-wrap mx-auto align-items-center">
        <!-- DEMO -->
        <div class="col iphone-container" id="demostration">
            <div class="shadow">
                <div class="iphone-device">
                    <section id="demo">
                        <div class="white-bkg"></div>
                        <header>
                            <img src="/images/logo.png" alt="Rhymance logo">
                        </header>
                        <!-- CARDS -->
                        <div class="cards">
                            <article>
                                <img src="/images/poems/Me hablaste.png" alt="Álex poem, 23 years old" class="poem-card-img" data-bs-toggle="modal" data-bs-target="#modalAlex" style="cursor: pointer;" title="Double click to view profile">
                                <h2>Álex <span>23</span></h2>
                                <div class="choice nope">NOPE</div>
                                <div class="choice like">LIKE</div>
                            </article>
                            <article>
                                <img src="/images/poems/No escribí.png" alt="Limary poem, 27 years old" class="poem-card-img" data-bs-toggle="modal" data-bs-target="#modalLimary" style="cursor: pointer;" title="Double click to view profile">
                                <h2>Limary <span>27</span></h2>
                                <div class="choice nope">NOPE</div>
                                <div class="choice like">LIKE</div>
                            </article>
                            <span>
                                No more poets near you...<br>
                                Try again later
                            </span>
                        </div>
                        <!-- END CARDS -->
                        <footer>
                            <button class="is-undo" aria-label="undo"></button>
                            <button class="is-remove is-big" aria-label="remove"></button>
                            <button class="is-star" aria-label="star"></button>
                            <button class="is-fav is-big" aria-label="fav"></button>
                            <button class="is-zap" aria-label="zap"></button>
                        </footer>
                    </section>
                </div>
            </div>
        </div>
        <!-- END DEMO -->
        <!-- Product Description -->
        <div class="col container px-5 mx-auto">
            <h2 class="display-4 fw-bold mb-4">Rhymance: Where poetry meets love</h2>
            <p class="lead mb-4">We revolutionize online dating with a unique proposal: instead of judging by photos, connect with souls through beautiful poems and verses.</p>
            
            <div class="row">
                <div class="col">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary text-white rounded-circle p-3 me-3">
                            <i class="bi bi-heart-fill"></i>
                        </div>
                        <div>
                            <h5 class="mb-1">Authentic connections</h5>
                            <small class="text-secondary">Based on literary sensitivity</small>
                        </div>
                    </div>
                </div>
                <a class="btn btn-primary col text-center d-flex align-items-center justify-content-center" href="/contact">
                    Contact Us
                </a>
            </div>
        </div>
        <!-- END product description -->
    </div>
</section>
