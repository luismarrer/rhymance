---
const testimonials = [
  {
    name: "Elena V.",
    text: "I never thought I could find someone who understood my metaphors. I found them here!",
    img: "https://randomuser.me/api/portraits/women/44.jpg",
    country: "Spain",
    time: "6 months",
    status: "In a happy relationship for 3 months",
  },
  {
    name: "Javier R.",
    text: "Tired of the superficial, Rhymance was a breath of fresh air. The conversations are incredible.",
    img: "https://randomuser.me/api/portraits/men/32.jpg",
    country: "Mexico",
    time: "1 year",
    status: "Meeting incredible people",
  },
  {
    name: "Carla G.",
    text: "It's like my book club where, hopefully, you fall in love. Highly recommended!",
    img: "https://randomuser.me/api/portraits/women/65.jpg",
    country: "Argentina",
    time: "8 months",
    status: "Dating someone special",
  },
  {
    name: "Miguel S.",
    text: "Finally a place where being 'intense' is a quality. I feel at home.",
    img: "https://randomuser.me/api/portraits/men/85.jpg",
    country: "Colombia",
    time: "3 months",
    status: "Exploring connections",
  },
]
---

<section id="experiences" class="py-20">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-center font-bold mb-12 text-white text-3xl">
      Rhyming Stories
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {
        testimonials.map((t) => (
          <div>
            <div class="testimonial-card rounded-xl shadow-sm h-full bg-[#2a2a2a]">
              <div class="text-center p-4 flex flex-col h-full">
                <div class="testimonial-avatar mx-auto mb-3">
                  <img
                    src={t.img}
                    alt={t.name}
                    class="rounded-full border-3 border-green-400 w-[100px] h-[100px] object-cover"
                    width="100"
                    height="100"
                  />
                </div>
                <h5 class="font-bold mb-1 text-lg">{t.name}</h5>
                <p class="text-white/50 text-sm mb-3">"{t.text}"</p>
                <div class="mt-auto">
                  <button
                    type="button"
                    class="relative text-passion border border-passion text-sm font-semibold px-4 py-1.5 rounded-md hover:bg-passion hover:text-white transition-colors"
                    data-popover-trigger
                    data-popover-title={`${t.name} - Details`}
                    data-popover-content={`Country: ${t.country}<br>Time using: ${t.time}<br>Status: ${t.status}`}
                  >
                    More info
                  </button>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
