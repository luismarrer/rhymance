---
import '../styles/app.css';
import '../styles/styles.css';
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="/images/favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <title>Contacto - Rhymance</title>
    <style>
        ::placeholder {
            color: rgba(255, 255, 255, 0.4) !important;
            opacity: 1;
        }
    </style>
</head>
<body class="bg-bg-dark text-text-dark">
    <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-3 mb-3 bg-bg-dark border-b border-[#38292A]">
        <a class="flex items-center text-white no-underline gap-1" href="/"><img src="/images/logo.png" alt="logo" width="50">Rhymance</a>
        <ul class="flex list-none gap-1 m-0 p-0">
            <li>
                <a class="text-white no-underline px-3 py-2 inline-block hover:text-white/80 transition-colors" href="/#home">Inicio</a>
            </li>
            <li>
                <a class="text-white no-underline px-3 py-2 inline-block hover:text-white/80 transition-colors" href="/#app">Aplicación</a>
            </li>
            <li>
                <a class="text-white no-underline px-3 py-2 inline-block hover:text-white/80 transition-colors" href="/#features">Funcionalidades</a>
            </li>
            <li>
                <a class="text-white no-underline px-3 py-2 inline-block hover:text-white/80 transition-colors" href="/#experiences">Experiencias</a>
            </li>
            <li>
                <a class="text-white no-underline px-3 py-2 inline-block hover:text-white/80 transition-colors" href="/#store">Usar</a>
            </li>
            <li>
                <a class="text-white no-underline px-5 py-2 inline-block rounded-full bg-passion hover:bg-passion-dark transition-colors" href="/contact">Contactar</a>
            </li>
        </ul>
    </nav>

    <main>
        <!-- Sección Hero de Contacto -->
        <section class="py-20" style="margin-top: 100px;">
            <div class="max-w-7xl mx-auto px-4">
                <div class="flex justify-center">
                    <div class="w-full lg:w-2/3 text-center mb-12">
                        <h1 class="text-5xl font-bold mb-3">Contáctanos</h1>
                        <p class="text-xl">
                            ¿Interesado en conocer más sobre nosotros? Completa el formulario y nuestro equipo se pondrá en contacto contigo.
                        </p>
                    </div>
                </div>

                <!-- Formulario de Contacto -->
                <div class="flex justify-center">
                    <div class="w-full lg:w-2/3">
                        <div class="rounded-2xl shadow-2xl overflow-hidden bg-[#1e1e1e]">
                            <div class="p-8 md:p-12">
                                <form id="contactForm">
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                        <!-- Nombre del Cliente -->
                                        <div class="md:col-span-2">
                                            <label for="clientName" class="block mb-2 font-semibold">Nombre completo <span class="text-passion">*</span></label>
                                            <input 
                                                type="text" 
                                                class="w-full px-4 py-3 rounded-lg border border-white/20 bg-bg-dark text-text-dark focus:border-passion focus:outline-none transition-colors" 
                                                id="clientName" 
                                                name="clientName"
                                                placeholder="Ingresa tu nombre completo"
                                                required
                                            >
                                        </div>

                                        <!-- País -->
                                        <div>
                                            <label for="country" class="block mb-2 font-semibold">País <span class="text-passion">*</span></label>
                                            <input 
                                                type="text" 
                                                class="w-full px-4 py-3 rounded-lg border border-white/20 bg-bg-dark text-text-dark focus:border-passion focus:outline-none transition-colors" 
                                                id="country" 
                                                name="country"
                                                placeholder="Ej: España, México, Puerto Rico"
                                                required
                                            >
                                        </div>

                                        <!-- Ciudad -->
                                        <div>
                                            <label for="city" class="block mb-2 font-semibold">Ciudad <span class="text-passion">*</span></label>
                                            <input 
                                                type="text" 
                                                class="w-full px-4 py-3 rounded-lg border border-white/20 bg-bg-dark text-text-dark focus:border-passion focus:outline-none transition-colors" 
                                                id="city" 
                                                name="city"
                                                placeholder="Ej: Madrid, CDMX, San Juan"
                                                required
                                            >
                                        </div>

                                        <!-- Correo Electrónico -->
                                        <div class="md:col-span-2">
                                            <label for="email" class="block mb-2 font-semibold">Correo electrónico <span class="text-passion">*</span></label>
                                            <input 
                                                type="email" 
                                                class="w-full px-4 py-3 rounded-lg border border-white/20 bg-bg-dark text-text-dark focus:border-passion focus:outline-none transition-colors" 
                                                id="email" 
                                                name="email"
                                                placeholder="tucorreo@ejemplo.com"
                                                required
                                            >
                                        </div>

                                        <!-- Nivel de subscripción -->
                                        <div class="md:col-span-2">
                                            <label for="subscriptionLevel" class="block mb-2 font-semibold">Nivel de subscripción</label>
                                            <select 
                                                class="w-full px-4 py-3 rounded-lg border border-white/20 bg-bg-dark text-text-dark focus:border-passion focus:outline-none transition-colors" 
                                                id="subscriptionLevel" 
                                                name="subscriptionLevel"
                                            >
                                                <option value="" selected disabled>Selecciona un nivel</option>
                                                <option value="rhymance-basic">Rhymance</option>
                                                <option value="rhymance-premium">Rhymance Plus</option>
                                                <option value="rhymance-enterprise">Rhymance Gold</option>
                                                <option value="rhymance-custom">Rhymance Platinum</option>
                                            </select>
                                        </div>

                                        <!-- Tipo de Cliente -->
                                        <div class="md:col-span-2">
                                            <label class="block mb-2 font-semibold">Tipo de cliente <span class="text-passion">*</span></label>
                                            <div class="flex gap-6">
                                                <label class="flex items-center gap-2 cursor-pointer">
                                                    <input 
                                                        class="w-4 h-4 accent-passion" 
                                                        type="radio" 
                                                        name="clientType" 
                                                        id="clientTypeIndividual" 
                                                        value="individual"
                                                        required
                                                    >
                                                    Particular
                                                </label>
                                                <label class="flex items-center gap-2 cursor-pointer">
                                                    <input 
                                                        class="w-4 h-4 accent-passion" 
                                                        type="radio" 
                                                        name="clientType" 
                                                        id="clientTypeCompany" 
                                                        value="company"
                                                    >
                                                    Empresa
                                                </label>
                                            </div>
                                        </div>

                                        <!-- Mensaje -->
                                        <div class="md:col-span-2">
                                            <label for="message" class="block mb-2 font-semibold">Mensaje <span class="text-passion">*</span></label>
                                            <textarea 
                                                class="w-full px-4 py-3 rounded-lg border border-white/20 bg-bg-dark text-text-dark focus:border-passion focus:outline-none transition-colors resize-y" 
                                                id="message" 
                                                name="message"
                                                rows="6"
                                                placeholder="Cuéntanos más sobre tu consulta o proyecto..."
                                                required
                                            ></textarea>
                                        </div>

                                        <!-- Botón de Envío -->
                                        <div class="md:col-span-2 text-center mt-4">
                                            <button type="submit" class="bg-passion text-white px-8 py-3 rounded-lg font-semibold text-lg hover:bg-passion-dark transition-colors inline-flex items-center gap-2">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M15.964.686a.5.5 0 0 0-.65-.65L.767 5.855H.766l-.452.18a.5.5 0 0 0-.082.887l.41.26.001.002 4.995 3.178 3.178 4.995.002.002.26.41a.5.5 0 0 0 .886-.083zm-1.833 1.89L6.637 10.07l-.215-.338a.5.5 0 0 0-.154-.154l-.338-.215 7.494-7.494 1.178-.471z"/>
                                                </svg>
                                                Enviar solicitud
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <!-- Mensaje de éxito (oculto por defecto) -->
                        <div id="successMessage" class="bg-green-500/20 border border-green-500 text-green-300 rounded-lg p-4 mt-4 hidden" role="alert">
                            <h5 class="font-bold flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                                </svg>
                                ¡Mensaje enviado con éxito!
                            </h5>
                            <p class="mb-0">Gracias por contactarnos. Nuestro equipo revisará tu solicitud y se pondrá en contacto contigo pronto.</p>
                        </div>
                    </div>
                </div>

                <!-- Información de Contacto Adicional -->
                <div class="flex justify-center mt-12">
                    <div class="w-full lg:w-2/3">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <div class="text-center">
                                <div class="p-4">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="#E63946" class="mb-3 inline-block" viewBox="0 0 16 16">
                                        <path d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414zM0 4.697v7.104l5.803-3.558zM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586zm3.436-.586L16 11.801V4.697z"/>
                                    </svg>
                                    <h5 class="font-bold mb-2">Email</h5>
                                    <a href="mailto:luismarrer.dev@gmail.com" class="text-passion no-underline hover:underline">luismarrer.dev@gmail.com</a>
                                </div>
                            </div>
                            <div class="text-center">
                                <div class="p-4">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="#D4A574" class="mb-3 inline-block" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd" d="M1.885.511a1.745 1.745 0 0 1 2.61.163L6.29 2.98c.329.423.445.974.315 1.494l-.547 2.19a.68.68 0 0 0 .178.643l2.457 2.457a.68.68 0 0 0 .644.178l2.189-.547a1.75 1.75 0 0 1 1.494.315l2.306 1.794c.829.645.905 1.87.163 2.611l-1.034 1.034c-.74.74-1.846 1.065-2.877.702a18.6 18.6 0 0 1-7.01-4.42 18.6 18.6 0 0 1-4.42-7.009c-.362-1.03-.037-2.137.703-2.877z"/>
                                    </svg>
                                    <h5 class="font-bold mb-2">Teléfono</h5>
                                    <a href="tel:+17874870310" class="text-passion no-underline hover:underline">+1 (787) 487-0310</a>
                                </div>
                            </div>
                            <div class="text-center">
                                <div class="p-4">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="#6A4C93" class="mb-3 inline-block" viewBox="0 0 16 16">
                                        <path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10m0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6"/>
                                    </svg>
                                    <h5 class="font-bold mb-2">Ubicación</h5>
                                    <p class="mb-0">San Juan, Puerto Rico</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white pt-20 pb-3 mt-12">
        <div class="max-w-7xl mx-auto px-4">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Columna 1: Logo y descripción -->
                <div>
                    <div class="flex items-center mb-3">
                        <img src="/images/logo.png" alt="Rhymance logo" width="50" class="mr-2">
                        <h5 class="mb-0 font-bold">Rhymance</h5>
                    </div>
                    <p class="text-white/50 text-sm">
                        Conectando almas a través de la poesía. Encuentra tu match literario perfecto.
                    </p>
                    <p class="text-white/50 text-sm mb-0">
                        Fabricado con ❤️ por Luis Marrero
                    </p>
                </div>
                
                <!-- Columna 2: Contacto -->
                <div>
                    <h6 class="font-bold mb-3">Contacto</h6>
                    <ul class="list-none p-0 text-white/50 text-sm">
                        <li class="mb-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="inline-block mr-2" viewBox="0 0 16 16">
                                <path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10m0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6"/>
                            </svg>
                            <a href="https://www.google.com/maps/place/San+Juan,+Puerto+Rico" target="_blank" rel="noopener noreferrer" class="text-white/50 no-underline hover:text-white transition-colors">San Juan, Puerto Rico</a>
                        </li>
                        <li class="mb-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="inline-block mr-2" viewBox="0 0 16 16">
                                <path d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414zM0 4.697v7.104l5.803-3.558zM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586zm3.436-.586L16 11.801V4.697z"/>
                            </svg>
                            <a href="mailto:luismarrer.dev@gmail.com" class="text-white/50 no-underline hover:text-white transition-colors">luismarrer.dev@gmail.com</a>
                        </li>
                        <li class="mb-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="inline-block mr-2" viewBox="0 0 16 16">
                                <path fill-rule="evenodd" d="M1.885.511a1.745 1.745 0 0 1 2.61.163L6.29 2.98c.329.423.445.974.315 1.494l-.547 2.19a.68.68 0 0 0 .178.643l2.457 2.457a.68.68 0 0 0 .644.178l2.189-.547a1.75 1.75 0 0 1 1.494.315l2.306 1.794c.829.645.905 1.87.163 2.611l-1.034 1.034c-.74.74-1.846 1.065-2.877.702a18.6 18.6 0 0 1-7.01-4.42 18.6 18.6 0 0 1-4.42-7.009c-.362-1.03-.037-2.137.703-2.877z"/>
                            </svg>
                            <a href="tel:+17874870310" class="text-white/50 no-underline hover:text-white transition-colors">+1 (787) 487-0310</a>
                        </li>
                    </ul>
                </div>
                
                <!-- Columna 3: Enlaces y Redes Sociales -->
                <div>
                    <h6 class="font-bold mb-3">Enlaces rápidos</h6>
                    <ul class="list-none p-0 text-white/50 text-sm mb-3">
                        <li class="mb-2"><a href="/#home" class="text-white/50 no-underline hover:text-white transition-colors">Inicio</a></li>
                        <li class="mb-2"><a href="/#app" class="text-white/50 no-underline hover:text-white transition-colors">Aplicación</a></li>
                        <li class="mb-2"><a href="/#features" class="text-white/50 no-underline hover:text-white transition-colors">Características</a></li>
                        <li class="mb-2"><a href="/contact" class="text-white/50 no-underline hover:text-white transition-colors">Contactar</a></li>
                        <li class="mb-2"><a href="https://luismarrer.github.io/en/" target="_blank" rel="noopener noreferrer" class="text-white/50 no-underline hover:text-white transition-colors">Portfolio</a></li>
                    </ul>
                    
                    <h6 class="font-bold mb-3">Síguenos</h6>
                    <div class="flex gap-3">
                        <a href="https://www.linkedin.com/in/luismarrer/" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-white transition-colors" aria-label="LinkedIn">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/>
                            </svg>
                        </a>
                        <a href="https://x.com/luismarrer_dev" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-white transition-colors" aria-label="Twitter/X">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.601.75Zm-.86 13.028h1.36L4.323 2.145H2.865z"/>
                            </svg>
                        </a>
                        <a href="https://github.com/luismarrer" target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-white transition-colors" aria-label="GitHub">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>
            
            <!-- Copyright -->
            <hr class="border-gray-600 my-4">
            <div class="flex flex-col md:flex-row justify-between">
                <div class="text-center md:text-left">
                    <p class="text-white/50 text-sm mb-0">
                        &copy; 2025 Rhymance. Todos los derechos reservados.
                    </p>
                </div>
                <div class="text-center md:text-right">
                    <a href="/privacy" class="text-white/50 no-underline text-sm mr-3 hover:text-white transition-colors">Política de Privacidad</a>
                    <a href="/terms" class="text-white/50 no-underline text-sm hover:text-white transition-colors">Términos y Condiciones</a>
                    <a href="/cookies" class="text-white/50 no-underline text-sm ml-3 hover:text-white transition-colors">Política de Cookies</a>
                </div>
            </div>
        </div>
    </footer>
    <script>
        // Manejo del formulario de contacto
        document.getElementById('contactForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const successMessage = document.getElementById('successMessage');
            successMessage.classList.remove('hidden');
            
            this.reset();
            
            successMessage.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            
            setTimeout(() => {
                successMessage.classList.add('hidden');
            }, 5000);
        });
    </script>
</body>
</html>
